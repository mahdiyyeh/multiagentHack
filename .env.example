# Tier 1 — required
# Get Gemini key from https://aistudio.google.com/apikey (must start with AIza...)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FALLBACKS=gemini-3.1-flash-lite-preview,gemini-3-flash-preview,gemini-2.5-pro
TAVILY_API_KEY=
SENSO_API_KEY=
SENSO_API_URL=https://apiv2.senso.ai/api/v1
# Optional — org is scoped via SENSO_API_KEY; search uses /org/search
SENSO_KB_ID=

# Tier 2 — sponsor prizes (graceful fallback if empty)
CLICKHOUSE_HOST=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=spaceraid
# Gensyn REE — no public API key portal; see scripts/setup_gensyn_ree.sh
GENSYN_REE_API_KEY=
GENSYN_REE_API_URL=
GENSYN_REE_LOCAL_REPO=
GENSYN_REE_USE_LOCAL=
GENSYN_REE_MODEL=Qwen/Qwen3-0.6B
# Prometheux — Ranker explainable ontology (https://platform.prometheux.ai/login)
PMTX_TOKEN=
PROMETHEUX_ORG=
PROMETHEUX_USERNAME=
PROMETHEUX_PROJECT_ID=
# Optional override; default https://api.prometheux.ai/jarvispy/<org>/<username>
PROMETHEUX_JARVISPY_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=
ELEVENLABS_API_KEY=
ENQUIRY_TO_EMAIL=
